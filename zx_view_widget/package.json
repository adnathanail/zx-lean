{
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "scripts": {
    "build": "tsc && rollup -c --environment NODE_ENV:production",
    "build-dev": "tsc && rollup -c --environment NODE_ENV:development",
    "watch": "rollup -c --environment NODE_ENV:production --watch",
    "build-lake": "tsc && rollup -c --environment NODE_ENV:production,OUTPUT_DIR:../.lake/build/js",
    "test": "vitest run"
  },
  "dependencies": {
    "@leanprover/infoview": "~0.8.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.1",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-replace": "^6.0.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "jsdom": "^28.1.0",
    "rollup": "^4.17.2",
    "typescript": "^5.0.3",
    "vitest": "^4.0.18"
  }
}
